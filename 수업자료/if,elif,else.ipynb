    "secret = input(\"1부터 100사이의 숫자를 입력하세요:\")\n",
    "\n",
    "guess = input(\"1부터 100사이의 숫자를 입력하세요:\")\n",
    "\n",
    "if guess < secret :\n",
    "    print(\"too low\")\n",
    "\n",
    "elif guess > secret :\n",
    "    print(\"too high\")\n",
    "\n",
    "else:\n",
    "    print(\"just right\")\n",
    "\n"
   ]
